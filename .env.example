APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=screenshut_telemetry
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SECURITY_OUTBOX_STALE_MINUTES=15
SECURITY_DELIVERY_TIMEOUT_SECONDS=30
SOCIAL_MEDIA_CLEANUP_GRACE_MINUTES=60
SOCIAL_MEDIA_JOB_TIMEOUT_SECONDS=60

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# OAuth "Web application" client ID from Google Cloud Console (audience of the
# Android app's Google ID token — see GoogleSignInOptions#requestIdToken).
GOOGLE_CLIENT_ID=

# Meta app credentials, used to verify Facebook Login access tokens via the Graph API.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Services ID (or app bundle ID) configured for Sign in with Apple.
APPLE_CLIENT_ID=

# Firebase Cloud Messaging push notifications. FIREBASE_PROJECT_ID is the Firebase
# project ID (Project Settings > General); FIREBASE_CREDENTIALS_PATH is an absolute path
# to a service-account JSON key (Project Settings > Service Accounts > Generate new
# private key) — never commit that file. Push sending is silently skipped, not an error,
# until both are set.
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

VITE_APP_NAME="${APP_NAME}"

# Shared secret an uptime monitor sends as the X-Health-Check-Secret header to reach
# /up/deep (dependency probes + queue backlog — not safe to leave public). Unset means
# the endpoint 404s for everyone.
HEALTH_CHECK_SECRET=
